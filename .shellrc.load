# include what you want

export PATH=$PATH:$HOME/bin

# add this to the .bashrc or .zshrc (done automatically by dfm):
# . $HOME/.shellrc.load

####
# put any bash/zsh customizations in here

alias ll='ls -l -h'
alias la='ls -A'
alias l='ls -al'
alias ..='cd ..'
alias ...='cd ../../'
alias df='df -h'
alias du='du -h'


